# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
S3_BUCKET_NAME=meteo-mlops-2026

# ── Neon Postgres ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
AIRFLOW_DB_URL=postgresql+psycopg2://user:password@host/dbname?sslmode=require

# ── MLflow + services (défaut : Docker local ; HF en prod) ────────────────────
# En local, viser le conteneur sur son port INTERNE 7860.
# (5000 n'est que le mapping hôte pour l'UI : http://localhost:5000)
MLFLOW_TRACKING_URI=http://mlflow:7860
MODEL_API_BASE_URL=http://model-api:7860
DATA_API_BASE_URL=http://data-api:7860

# Artefacts MLflow (modèles sérialisés) — bucket S3 dédié.
# Requis par le serveur MLflow (docker-compose : ARTIFACT_ROOT).
MLFLOW_ARTIFACT_ROOT=s3://meteo-mlops-2026/mlflow-artifacts

# SOURCE DE VÉRITÉ UNIQUE — le serveur MLflow (local ET Space HF) stocke ses
# métadonnées (runs, modèles, alias) dans le backend store. En local,
# docker-compose injecte BACKEND_STORE_URI = DATABASE_URL ci-dessus.
# Pour que l'UI HF affiche EXACTEMENT les mêmes runs que l'UI locale, le secret
# du Space meteo-mlflow doit valoir :
#   BACKEND_STORE_URI = <même valeur que DATABASE_URL>
#   ARTIFACT_ROOT     = <même valeur que MLFLOW_ARTIFACT_ROOT>
# Toute divergence de ces deux secrets fait diverger les deux UI.

# Bascule prod HuggingFace Spaces — remplacer les 3 URLs ci-dessus par :
#   MLFLOW_TRACKING_URI=https://erimer974-meteo-mlflow.hf.space
#   MODEL_API_BASE_URL=https://erimer974-meteo-model-api.hf.space
#   DATA_API_BASE_URL=https://erimer974-meteo-data-api.hf.space

# ── ETL ───────────────────────────────────────────────────────────────────────
DATA_API_ENDPOINT=/current-weather
DATA_API_BATCH_SIZE=20
DATA_API_SLEEP_SECONDS=1.0
MODEL_API_PREDICT_ENDPOINT=/predict
MODEL_API_TIMEOUT=120

# ── Base de données ───────────────────────────────────────────────────────────
DB_TARGET_TABLE=meteo_predictions

# ── S3 prefixes ───────────────────────────────────────────────────────────────
# Le jeu de référence du monitoring est sous {S3_RAW_PREFIX}/monitor/
# (écrit par prepare_data.py), pas besoin d'un préfixe séparé.
S3_RAW_PREFIX=raw/meteo
S3_PROD_PREFIX=production/meteo

# ── Monitoring ────────────────────────────────────────────────────────────────
# Part de colonnes en drift au-delà de laquelle on déclenche un retraining.
DRIFT_SHARE_THRESHOLD=0.5

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_GID=0
# NB : docker-compose épingle l'image en dur (apache/airflow:2.10.5-python3.11).
# Cette variable n'est utilisée que par le airflow/Dockerfile optionnel (non buildé
# par défaut) ; gardée alignée pour cohérence.
AIRFLOW_IMAGE_NAME=apache/airflow:2.10.5-python3.11
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
