# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
S3_BUCKET_NAME=meteo-mlops-2026

# ── Neon Postgres ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── HuggingFace Spaces ────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=https://your-username-meteo-mlflow.hf.space
MODEL_API_BASE_URL=https://your-username-meteo-model-api.hf.space
DATA_API_BASE_URL=https://your-username-meteo-data-api.hf.space

# ── ETL ───────────────────────────────────────────────────────────────────────
DATA_API_ENDPOINT=/current-weather
DATA_API_BATCH_SIZE=20
DATA_API_SLEEP_SECONDS=1.0
MODEL_API_PREDICT_ENDPOINT=/predict
MODEL_API_TIMEOUT=120

# ── Base de données ───────────────────────────────────────────────────────────
DB_TARGET_TABLE=meteo_predictions

# ── S3 prefixes ───────────────────────────────────────────────────────────────
S3_RAW_PREFIX=raw/meteo
S3_PROD_PREFIX=production/meteo
S3_MONITOR_PREFIX=monitor/meteo
